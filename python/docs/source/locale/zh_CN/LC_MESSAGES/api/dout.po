#: adctoolbox.dout.analyze_enob_sweep.analyze_enob_sweep:18
#: adctoolbox.dout.analyze_overflow.analyze_overflow:15
#: adctoolbox.dout.analyze_weight_radix.analyze_weight_radix:13 of
msgid "Axes to plot on. If None, uses current axes (plt.gca())"
msgstr ""

#: adctoolbox.dout.analyze_bit_activity.analyze_bit_activity:12
#: adctoolbox.dout.analyze_enob_sweep.analyze_enob_sweep:20
#: adctoolbox.dout.analyze_weight_radix.analyze_weight_radix:15 of
msgid "Title for the plot. If None, uses default title"
msgstr ""

#: adctoolbox.dout.analyze_bit_activity.analyze_bit_activity:15 of
msgid "Percentage of 1's for each bit (1D array of length B)"
msgstr ""

#: adctoolbox.dout.analyze_overflow.analyze_overflow:1 of
msgid ""
"Analyze residue distribution at each bit position for overflow detection."
msgstr ""

#: adctoolbox.dout.analyze_overflow.analyze_overflow:3 of
msgid ""
"Calculates normalized residue (remaining bits weighted sum) and detects "
"overflow conditions where residue exceeds [0, 1] range."
msgstr ""

#: adctoolbox.dout.analyze_overflow.analyze_overflow:6 of
msgid "Digital codes array, shape (N, M) where N=samples, M=bits (MSB first)"
msgstr ""

#: adctoolbox.dout.analyze_overflow.analyze_overflow:8 of
msgid "Weight array for each bit, shape (M,)"
msgstr ""

#: adctoolbox.dout.analyze_overflow.analyze_overflow:10 of
msgid ""
"Overflow bit position for overflow detection. Default is M (check at MSB, "
"MATLAB convention: 1=LSB, M=MSB)"
msgstr ""

#: adctoolbox.dout.analyze_overflow.analyze_overflow:13 of
msgid "If True, generate residue distribution visualization"
msgstr ""

#: adctoolbox.dout.analyze_overflow.analyze_overflow:17 of
msgid "Title for the plot. If None, no title is set"
msgstr ""

#: adctoolbox.dout.analyze_overflow.analyze_overflow:20 of
msgid ""
"- range_min: Minimum normalized residue per bit (shape M,) - range_max: "
"Maximum normalized residue per bit (shape M,) - ovf_percent_zero: Underflow "
"percentage per bit (shape M,) - ovf_percent_one: Overflow percentage per bit "
"(shape M,)"
msgstr ""

#: adctoolbox.dout.analyze_overflow.analyze_overflow:22 of
msgid "range_min: Minimum normalized residue per bit (shape M,)"
msgstr ""

#: adctoolbox.dout.analyze_overflow.analyze_overflow:23 of
msgid "range_max: Maximum normalized residue per bit (shape M,)"
msgstr ""

#: adctoolbox.dout.analyze_overflow.analyze_overflow:24 of
msgid "ovf_percent_zero: Underflow percentage per bit (shape M,)"
msgstr ""

#: adctoolbox.dout.analyze_overflow.analyze_overflow:25 of
msgid "ovf_percent_one: Overflow percentage per bit (shape M,)"
msgstr ""

#: adctoolbox.dout.analyze_enob_sweep.analyze_enob_sweep:32
#: adctoolbox.dout.analyze_overflow.analyze_overflow:29
#: adctoolbox.dout.analyze_weight_radix.analyze_weight_radix:32 of
msgid "Notes"
msgstr ""

#: adctoolbox.dout.analyze_overflow.analyze_overflow:30 of
msgid "A bit segment is the sub-code formed from one bit to the LSB"
msgstr ""

#: adctoolbox.dout.analyze_overflow.analyze_overflow:31 of
msgid "Residue is normalized by dividing by the sum of weights in the segment"
msgstr ""

#: adctoolbox.dout.analyze_overflow.analyze_overflow:32 of
msgid "Matches MATLAB ovfchk.m behavior exactly"
msgstr ""

#: adctoolbox.dout.analyze_weight_radix.analyze_weight_radix:1 of
msgid "Analyze absolute bit weights, radix ratios, and weight-list resolution."
msgstr ""

#: adctoolbox.dout.analyze_weight_radix.analyze_weight_radix:3 of
msgid ""
"Pure binary: radix = 2.00. Sub-radix/redundancy: radix < 2.00. ``effres`` is "
"a theoretical resolution estimate from the supplied weight dynamic range, "
"not a missing-code/DNL proof."
msgstr ""

#: adctoolbox.dout.analyze_weight_radix.analyze_weight_radix:7 of
msgid ""
"Bit weights (1D array), nominally from MSB to LSB for radix plotting. "
"Effective-resolution analysis uses sorted absolute magnitudes, so negative "
"trim weights count by magnitude."
msgstr ""

#: adctoolbox.dout.analyze_weight_radix.analyze_weight_radix:11 of
msgid "If True, create line plot with radix annotations"
msgstr ""

#: adctoolbox.dout.analyze_weight_radix.analyze_weight_radix:18 of
msgid ""
"``radix``:     Radix between consecutive input-order weights,     "
"``abs(weight[i-1]) / abs(weight[i])``. The first entry is ``NaN``. "
"``wgtsca``:     Scale factor that maps the significant absolute weights "
"closest to     integer LSB units. ``effres``:     Effective resolution in "
"bits,     ``log2(sum(abs_w_sig) / min(abs_w_sig) + 1)``."
msgstr ""

#: adctoolbox.dout.analyze_weight_radix.analyze_weight_radix:20 of
msgid "``radix``:"
msgstr ""

#: adctoolbox.dout.analyze_weight_radix.analyze_weight_radix:21 of
msgid ""
"Radix between consecutive input-order weights, ``abs(weight[i-1]) / "
"abs(weight[i])``. The first entry is ``NaN``."
msgstr ""

#: adctoolbox.dout.analyze_weight_radix.analyze_weight_radix:23 of
msgid "``wgtsca``:"
msgstr ""

#: adctoolbox.dout.analyze_weight_radix.analyze_weight_radix:24 of
msgid ""
"Scale factor that maps the significant absolute weights closest to integer "
"LSB units."
msgstr ""

#: adctoolbox.dout.analyze_weight_radix.analyze_weight_radix:26 of
msgid "``effres``:"
msgstr ""

#: adctoolbox.dout.analyze_weight_radix.analyze_weight_radix:27 of
msgid ""
"Effective resolution in bits, ``log2(sum(abs_w_sig) / min(abs_w_sig) + 1)``."
msgstr ""

#: adctoolbox.dout.analyze_weight_radix.analyze_weight_radix:33 of
msgid ""
"The significant set ``abs_w_sig`` is formed by sorting ``abs(weights)`` in "
"descending order, then dropping the tail after the first adjacent ratio ``>= "
"3``. This excludes very small trim/noise weights from ``effres``."
msgstr ""

#: adctoolbox.dout.analyze_weight_radix.analyze_weight_radix:37 of
msgid ""
"``effres`` is useful for questions like \"how many bits does this SAR weight "
"list span?\" It does not verify SAR decision reachability, code "
"monotonicity, missing codes, DNL/INL, comparator noise, or sampling noise."
msgstr ""

#: adctoolbox.dout.analyze_weight_radix.analyze_weight_radix:41 of
msgid ""
"What to look for in radix values: - Radix = 2.00: Binary scaling (SAR, pure "
"binary) - Radix < 2.00: Redundancy or sub-radix (e.g., 1.5-bit/stage → "
"~1.90) - Radix > 2.00: Unusual, may indicate calibration error - Consistent "
"pattern: Expected architecture behavior - Random jumps: Calibration errors "
"or bit mismatch"
msgstr ""

#: ../../source/api/dout.rst:27
msgid "ENOB Analysis"
msgstr ""

#: adctoolbox.dout.analyze_enob_sweep.analyze_enob_sweep:1 of
msgid "Sweep ENOB vs number of bits used for calibration."
msgstr ""

#: adctoolbox.dout.analyze_enob_sweep.analyze_enob_sweep:3 of
msgid ""
"Incrementally adds bits (MSB to LSB) and measures ENOB after calibration to "
"understand diminishing returns and optimal bit count."
msgstr ""

#: adctoolbox.dout.analyze_enob_sweep.analyze_enob_sweep:6 of
msgid "Binary matrix (N samples x M bits, MSB to LSB order)"
msgstr ""

#: adctoolbox.dout.analyze_enob_sweep.analyze_enob_sweep:8 of
msgid "Normalized frequency (0-0.5). If None, auto-detect from data"
msgstr ""

#: adctoolbox.dout.analyze_enob_sweep.analyze_enob_sweep:10 of
msgid "Harmonic order for calibrate_weight_sine"
msgstr ""

#: adctoolbox.dout.analyze_enob_sweep.analyze_enob_sweep:12 of
msgid "Oversampling ratio for spectrum analysis"
msgstr ""

#: adctoolbox.dout.analyze_enob_sweep.analyze_enob_sweep:14 of
msgid "Window function: 'boxcar', 'hann', 'hamming'"
msgstr ""

#: adctoolbox.dout.analyze_enob_sweep.analyze_enob_sweep:16 of
msgid "If True, plot ENOB sweep curve"
msgstr ""

#: adctoolbox.dout.analyze_enob_sweep.analyze_enob_sweep:22 of
msgid "If True, print progress messages"
msgstr ""

#: adctoolbox.dout.analyze_enob_sweep.analyze_enob_sweep:25 of
msgid ""
"- enob_sweep: ENOB for each bit count (length M) - n_bits_vec: Bit counts "
"from 1 to M"
msgstr ""

#: adctoolbox.dout.analyze_enob_sweep.analyze_enob_sweep:27 of
msgid "enob_sweep: ENOB for each bit count (length M)"
msgstr ""

#: adctoolbox.dout.analyze_enob_sweep.analyze_enob_sweep:28 of
msgid "n_bits_vec: Bit counts from 1 to M"
msgstr ""

#: adctoolbox.dout.analyze_enob_sweep.analyze_enob_sweep:33 of
msgid ""
"What to look for in the plot: - Increasing trend: More bits improve "
"resolution - Plateau: Additional bits don't help (noise/distortion limited) "
"- Decrease: Extra bits add noise/calibration errors"
msgstr ""

#: ../../source/api/dout.rst:32
msgid "Visualization"
msgstr ""

#: adctoolbox.dout.plot_residual_scatter.plot_residual_scatter:1 of
msgid "Plot partial-sum residuals of an ADC bit matrix."
msgstr ""

#: adctoolbox.dout.plot_residual_scatter.plot_residual_scatter:3 of
msgid ""
"For each pair (x_bit, y_bit), computes the residual after subtracting the "
"first x_bit (or y_bit) weighted bits from the input signal, then plots y-"
"residual vs x-residual as a scatter plot."
msgstr ""

#: adctoolbox.dout.plot_residual_scatter.plot_residual_scatter:7 of
msgid "Ideal input signal to the ADC (1D, length N)."
msgstr ""

#: adctoolbox.dout.plot_residual_scatter.plot_residual_scatter:9 of
msgid "Raw ADC output bit matrix (N x M), MSB-first columns."
msgstr ""

#: adctoolbox.dout.plot_residual_scatter.plot_residual_scatter:11 of
msgid "Bit weights (length M). Default: binary [2^(M-1), ..., 1]."
msgstr ""

#: adctoolbox.dout.plot_residual_scatter.plot_residual_scatter:13 of
msgid ""
"Pairs of bit indices whose residuals are plotted. Range: 0 (raw signal) to M "
"(residual after all bits). Default: [(0, M), (1, M), ..., (M-1, M)]."
msgstr ""

#: adctoolbox.dout.plot_residual_scatter.plot_residual_scatter:17 of
msgid "Marker transparency. 'auto' scales as clamp(1000/N, 0.1, 1.0)."
msgstr ""

#: adctoolbox.dout.plot_residual_scatter.plot_residual_scatter:19 of
msgid "If True, create scatter subplots."
msgstr ""

#: adctoolbox.dout.plot_residual_scatter.plot_residual_scatter:22 of
msgid ""
"'pairs': list of (x_bit, y_bit) tuples used 'residuals_x': list of 1D "
"arrays, one per pair 'residuals_y': list of 1D arrays, one per pair"
msgstr ""

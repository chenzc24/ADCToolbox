#: ../../source/api/dout.rst:15
msgid "Bit And Weight Analysis"
msgstr ""

#: ../../source/api/dout.rst:17
msgid ""
"``analyze_weight_radix`` returns ``radix``, ``wgtsca``, and ``effres``. "
"``effres`` is computed from the significant absolute weights as "
"``log2(sum(abs_w_sig) / min(abs_w_sig) + 1)``. It is a theoretical weight-"
"list span, not a missing-code, DNL, INL, or SAR reachability proof."
msgstr ""

#: adctoolbox.dout.analyze_bit_activity.analyze_bit_activity:1 of
msgid "Analyze and plot the percentage of 1's in each bit."
msgstr ""

#: adctoolbox.dout.analyze_bit_activity.analyze_bit_activity:3 of
msgid ""
"Ideal SAR ADC should have 50% activity for all bits. Deviations indicate "
"input signal DC offset or amplitude clipping."
msgstr ""

#: adctoolbox.dout.analyze_bit_activity.analyze_bit_activity:6 of
msgid "Binary matrix (N x B), N=samples, B=bits (MSB to LSB)"
msgstr ""

#: adctoolbox.dout.analyze_bit_activity.analyze_bit_activity:8 of
msgid "If True, create bar chart visualization"
msgstr ""


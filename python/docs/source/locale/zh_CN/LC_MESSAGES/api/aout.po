msgid "Numerics (from raw fitting):"
msgstr ""

#: adctoolbox.aout.rearrange_error_by_phase.rearrange_error_by_phase:15 of
msgid ""
"am_noise_rms_v, pm_noise_rms_v, pm_noise_rms_rad, noise_floor_rms_v, "
